# ── Platform connection (required) ──────────────────────────────────────────
# Get these from your dashboard → Bot Settings → Your Bot Credentials
PLATFORM_URL=https://kael.polarisdgtl.com
PLATFORM_USER_ID=YOUR_USER_ID_HERE
BOT_API_KEY=YOUR_BOT_API_KEY_HERE
LICENSE_KEY=KAEL-XXXX-XXXX-XXXX-XXXX

# ── Broker ───────────────────────────────────────────────────────────────────
# Options: paper | topstep | tradovate | apex | bulenox | tpt | ftmo
# Start with "paper" to test. Switch to your prop firm once you're ready.
BROKER=paper

# ── TopstepX credentials (only if BROKER=topstep) ───────────────────────────
# TOPSTEP_USERNAME=
# TOPSTEP_API_KEY=

# ── Tradovate / Prop Firm credentials ────────────────────────────────────────
# Used for: tradovate, apex, bulenox, tpt, ftmo
# Get CID and SEC from: tradovate.com → My Apps → Register New App
# TRADOVATE_CID=
# TRADOVATE_SEC=

# ── Optional: Discord trade alerts ──────────────────────────────────────────
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
